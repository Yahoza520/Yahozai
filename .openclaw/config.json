{
  "model": "llama3.2:1b",
  "provider": "ollama",
  "settings": {
    "temperature": 0.7,
    "maxTokens": 4096,
    "topP": 0.9,
    "timeout": 30000,
    "baseUrl": "http://localhost:11434"
  },
  "memory": {
    "maxHistoryTokens": 8000,
    "persistenceEnabled": true,
    "storageDir": "./memory"
  },
  "performance": {
    "batchSize": 5,
    "parallelRequests": 2,
    "cacheResponses": true
  },
  "logging": {
    "level": "info",
    "file": "./logs/openclaw.log",
    "maxFileSize": "10MB",
    "maxFiles": 5
  }
}
